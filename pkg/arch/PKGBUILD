# Maintainer: th3cavalry <github.com/th3cavalry>
pkgname=gz302-linux-setup
pkgver=6.6.4
pkgrel=1
pkgdesc="Linux optimization suite for ASUS ROG Flow Z13 (GZ302) — z13ctl backend"
arch=('any')
url="https://github.com/th3cavalry/GZ302-Linux-Setup"
license=('MIT')
depends=('bash' 'curl')
optdepends=(
    'python-pyqt6: System tray command center'
    'python-psutil: Battery monitoring in tray app'
    'z13ctl: Hardware control backend (installed by setup)'
    'steam: Gaming support (optional module)'
    'ollama: AI support (optional module)'
)
source=("${url}/archive/refs/heads/main.zip")
sha256sums=('SKIP')

package() {
    cd "$srcdir/GZ302-Linux-Setup-main"

    # Install main setup script
    install -Dm755 gz302-setup.sh "$pkgdir/usr/local/bin/gz302-setup"

    # Install libraries
    install -d "$pkgdir/usr/local/share/gz302/gz302-lib"
    install -Dm644 gz302-lib/*.sh "$pkgdir/usr/local/share/gz302/gz302-lib/"
    install -Dm644 VERSION "$pkgdir/usr/local/share/gz302/VERSION"

    # Install optional modules
    install -d "$pkgdir/usr/local/share/gz302/modules"
    install -Dm644 modules/*.sh "$pkgdir/usr/local/share/gz302/modules/"

    # Install tray app
    install -d "$pkgdir/usr/local/share/gz302/command-center"
    cp -r command-center/* "$pkgdir/usr/local/share/gz302/command-center/"

    # Install scripts
    install -d "$pkgdir/usr/local/share/gz302/scripts"
    install -Dm755 scripts/fix-suspend.sh "$pkgdir/usr/local/share/gz302/scripts/"
    install -d "$pkgdir/usr/local/share/gz302/scripts/uninstall"
    install -Dm755 scripts/uninstall/gz302-uninstall.sh "$pkgdir/usr/local/share/gz302/scripts/uninstall/"
}
